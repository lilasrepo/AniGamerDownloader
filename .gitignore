# WebView2 bootstrapper blob (build_desktop.bat re-downloads it on demand)
shells/webview2/*.exe

# --- public-repo hygiene -----------------------------------------------------
# Self-signed localhost TLS cert: never commit a private key. It is generated on
# demand under data/sslkey/ the first time the dashboard's SSL option is enabled.
web/sslkey/
data/sslkey/
# Retired vendor/pre-restructure files — local reference only, not part of the app.
archived/
# Legacy compat shims (re-export from core/app). The exe / aniGamer.bat / Docker
# launchers all run core+app directly and never load src/ — kept locally only as
# reference, excluded from the public repo (slated for deletion at project end).
src/
# Claude Code workspace config + project instructions — dev tooling, not shipped.
.claude/
CLAUDE.md
# Local-only alt build path (PyInstaller .spec is *.spec-ignored above). The
# public, verified build path is scripts/build_desktop.bat + CI.
shells/build_desktop.ps1
